@using LinqStudio.Blazor.Models

<MudDialog data-testid="project-browser-dialog">
	<TitleContent>
		<MudText Typo="Typo.h6">
			@(Mode == ProjectBrowserMode.Open ? "Open Project" : "Save Project As")
		</MudText>
	</TitleContent>
	<DialogContent>
		<MudStack Spacing="3">
			@if (_errorMessage is not null)
			{
				<MudAlert Severity="Severity.Error" data-testid="project-browser-error">@_errorMessage</MudAlert>
			}

			@if (Mode == ProjectBrowserMode.SaveAs)
			{
				<MudTextField T="string"
							  @bind-Value="_projectName"
							  Label="Project name"
							  Variant="Variant.Outlined"
							  Immediate="true"
							  data-testid="project-name-input" />
			}

			@if (_isLoading)
			{
				<MudStack AlignItems="AlignItems.Center" Class="pa-4">
					<MudProgressCircular Indeterminate="true" data-testid="loading-spinner" />
				</MudStack>
			}
			else if (_projects.Count == 0)
			{
				<MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4" data-testid="no-projects-message">
					No saved projects yet.
				</MudText>
			}
			else
			{
				<MudList T="ProjectSummary" data-testid="project-list">
					@foreach (var project in _projects)
					{
						var isSelected = _selected?.Id == project.Id;
						<MudListItem T="ProjectSummary"
									 @key="@project.Id"
									 OnClick="@(() => SelectProject(project))"
									 Class="@(isSelected ? "mud-selected-item" : string.Empty)"
									 data-testid="project-list-item">
							<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
								<MudStack Spacing="0">
									<MudText Typo="Typo.body1" data-testid="project-item-name">@project.Name</MudText>
									<MudText Typo="Typo.caption" Color="Color.Secondary" data-testid="project-item-date">
										Modified @project.ModifiedDate.LocalDateTime.ToString("MMM d, yyyy h:mm tt")
									</MudText>
								</MudStack>
								<span @onclick:stopPropagation="true">
									<MudIconButton Icon="@Icons.Material.Filled.Delete"
												   Size="Size.Small"
												   Color="Color.Error"
												   OnClick="@(() => DeleteProjectAsync(project))"
												   data-testid="project-delete-btn" />
								</span>
							</MudStack>
						</MudListItem>
					}
				</MudList>
			}
		</MudStack>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel" data-testid="project-browser-cancel-btn">Cancel</MudButton>
		@if (Mode == ProjectBrowserMode.Open)
		{
			<MudButton Color="Color.Primary"
					   Variant="Variant.Filled"
					   Disabled="_selected is null"
					   OnClick="Confirm"
					   data-testid="project-browser-open-btn">
				Open
			</MudButton>
		}
		else
		{
			<MudButton Color="Color.Primary"
					   Variant="Variant.Filled"
					   Disabled="@(string.IsNullOrWhiteSpace(_projectName))"
					   OnClick="Confirm"
					   data-testid="project-browser-save-btn">
				Save
			</MudButton>
		}
	</DialogActions>
</MudDialog>
