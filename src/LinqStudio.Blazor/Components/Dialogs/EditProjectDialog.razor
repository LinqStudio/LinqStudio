@using LinqStudio.Core.Models

<MudDialog data-testid="edit-project-dialog">
	<DialogContent>
		<MudTextField Value="@Project.Name" 
					  Label="Project Name" 
					  ReadOnly="true"
					  Disabled="true"
					  data-testid="project-name-field" />
		
		<MudTextField @bind-Value="_connectionString" 
					  Label="Connection String" 
					  Class="mt-4"
					  Lines="3"
					  data-testid="project-connection-string-field" />
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel" data-testid="edit-project-cancel-btn">Cancel</MudButton>
		<MudButton Color="Color.Primary" 
				   Variant="Variant.Filled" 
				   OnClick="Save"
				   data-testid="edit-project-save-btn">
			Save
		</MudButton>
	</DialogActions>
</MudDialog>