@page "/editor"
@page "/editor/{QueryIdParam:guid}"
@page "/editor/new"
@using BlazorMonaco
@using BlazorMonaco.Editor
@using BlazorMonaco.Languages
@using LinqStudio.Blazor.Components

<PageTitle>Editor - LinqStudio</PageTitle>

<div class="editor-page pa-2" style="height:100%; display:flex; flex-direction:column; gap:8px" data-testid="editor-page">
	@if (Workspace.IsProjectOpen)
	{
		@if (Workspace.Queries.CurrentQueryId is not null)
		{
			<!-- Query Tabs -->
			<MudPaper Class="pa-1" Elevation="1">
				<MudTabs Rounded="true" ApplyEffectsToContainer="true">
					@foreach (var q in GetOpenQueriesInOrder())
					{
						var isOpen = Workspace.Queries.OpenQueries.TryGetValue(q.Id, out var state);
						var tabName = (isOpen && state?.HasUnsavedChanges == true) ? $"{q.Name} *" : q.Name;
						<MudTabPanel 
							Text="@tabName" 
							OnClick="@(() => NavigateToQuery(q.Id))" />
					}
				</MudTabs>
			</MudPaper>

			<!-- Query Info Bar -->
			<MudPaper Class="pa-2" Elevation="1" data-testid="query-info-bar">
			<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
					<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
					<MudText Typo="Typo.body1" data-testid="query-name-display">
						<strong>@(Workspace.Queries.GetCurrentQuery()?.Name ?? "New Query")</strong>
					</MudText>

					@if (Workspace.Queries.CurrentQueryState?.HasUnsavedChanges == true)
					{
						<MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Edit" data-testid="query-unsaved-indicator">Unsaved</MudChip>
					}
				</MudStack>

				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
					<MudTooltip Text="Save query">
						<MudIconButton Icon="@Icons.Material.Filled.Save"
									   Color="Color.Primary"
									   Size="Size.Small"
									   OnClick="SaveCurrentQuery"
									   Disabled="@(Workspace.Queries.CurrentQueryId is null)"
									   data-testid="query-save-btn" />
					</MudTooltip>

					<MudTooltip Text="Close query">
						<MudIconButton Icon="@Icons.Material.Filled.Close"
									   Color="Color.Primary"
									   Size="Size.Small"
									   OnClick="CloseCurrentQuery"
									   Disabled="@(Workspace.Queries.CurrentQueryId is null)"
									   data-testid="query-close-btn" />
					</MudTooltip>
				</MudStack>
			</MudStack>
		</MudPaper>

		<!-- Monaco Editor -->
		<div class="editor-top" style="flex:1" data-testid="monaco-editor-container">
			@if (!Delay)
			{
				<StandaloneCodeEditor @ref="_editor"
									  Id="editor-top"
									  CssClass="editor"
									  ConstructionOptions="EditorConstructionOptions"
									  OnDidInit="OnEditorInitialized"
									  OnDidChangeModelContent="OnEditorContentChanged" />
			}
		</div>

		<!-- Query Execution Actions -->
		<MudPaper Class="pa-2" Elevation="1" data-testid="query-execution-bar">
			<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
					@{
						var execState = GetCurrentExecutionState();
					}
					@if (execState.IsExecuting)
					{
						<MudButton StartIcon="@Icons.Material.Filled.Stop"
								   Color="Color.Error"
								   Size="Size.Small"
								   Variant="Variant.Filled"
								   OnClick="StopCurrentQuery"
								   data-testid="stop-query-btn">
							Stop
						</MudButton>
					}
					else
					{
						<MudButton StartIcon="@Icons.Material.Filled.PlayArrow"
								   Color="Color.Primary"
								   Size="Size.Small"
								   Variant="Variant.Filled"
								   OnClick="ExecuteCurrentQueryAsync"
								   Disabled="@(Workspace.Queries.CurrentQueryId is null)"
								   data-testid="execute-query-btn">
							Execute
						</MudButton>
					}

					<div data-testid="timeout-select">
						<MudSelect T="int" 
								@bind-Value="_selectedTimeout" 
								Variant="Variant.Outlined" 
								Dense="true"
								Disabled="@execState.IsExecuting">
							<MudSelectItem T="int" Value="10">10s</MudSelectItem>
							<MudSelectItem T="int" Value="30">30s</MudSelectItem>
							<MudSelectItem T="int" Value="60">1 min</MudSelectItem>
							<MudSelectItem T="int" Value="120">2 min</MudSelectItem>
							<MudSelectItem T="int" Value="300">5 min</MudSelectItem>
							<MudSelectItem T="int" Value="0">No timeout</MudSelectItem>
						</MudSelect>
					</div>
				</MudStack>

				<MudTooltip Text="Refresh IntelliSense schema from database">
					<MudButton StartIcon="@Icons.Material.Filled.Refresh"
							   Color="Color.Primary"
							   Size="Size.Small"
							   Variant="Variant.Text"
							   OnClick="RefreshSchemaAsync"
							   Disabled="@(_isRefreshingSchema || Workspace.CurrentProject?.QueryGenerator is null)"
							   data-testid="refresh-schema-btn">
						@if (_isRefreshingSchema)
						{
							<MudProgressCircular Size="Size.Small" Indeterminate="true" />
							<span style="margin-left:4px">Refreshing...</span>
						}
						else
						{
							<span>Refresh Schema</span>
						}
					</MudButton>
				</MudTooltip>
			</MudStack>
		</MudPaper>

		<!-- Query Result Grid -->
		<div style="flex:1; overflow:auto" data-testid="query-result-container">
			<QueryResultGrid Result="@GetCurrentExecutionState().Result" 
							 IsExecuting="@GetCurrentExecutionState().IsExecuting" />
		</div>

		<!-- Editor Info -->
		<MudPaper Class="pa-2" Elevation="1" data-testid="editor-info-bar">
			<MudText Typo="Typo.body2" Color="Color.Secondary">
				Editor provides IntelliSense using Roslyn compiler with EF Core support
			</MudText>
		</MudPaper>
		}
		else
		{
			<!-- No queries open -->
			<MudAlert Severity="Severity.Info" data-testid="no-query-alert">
				No queries are currently open. Create a new query or open an existing one from the Editor menu.
			</MudAlert>
		}
	}
	else
	{
		<MudAlert Severity="Severity.Info" data-testid="no-project-alert">
			No project is open. Please create or open a project to start editing queries.
		</MudAlert>
	}
</div>
