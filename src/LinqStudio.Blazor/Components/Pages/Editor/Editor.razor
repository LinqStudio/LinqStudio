@page "/editor"
@page "/editor/{QueryIndexParam}"
@page "/editor/new"
@using BlazorMonaco
@using BlazorMonaco.Editor
@using BlazorMonaco.Languages

<PageTitle>Editor - LinqStudio</PageTitle>

<div class="editor-page pa-2" style="height:100%; display:flex; flex-direction:column; gap:8px" data-testid="editor-page">
	@if (Workspace.IsProjectOpen)
	{
		<!-- Query Info Bar -->
		<MudPaper Class="pa-2" Elevation="1" data-testid="query-info-bar">
			<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
					<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
					
					@if (_isEditingName)
					{
						<MudTextField @bind-Value="_editedQueryName"
									  Variant="Variant.Outlined"
									  Margin="Margin.Dense"
									  Immediate="true"
									  Validation="@(new Func<string, string?>(ValidateQueryName))"
									  OnKeyDown="OnNameKeyDown"
									  Class="query-name-editor"
									  Style="max-width: 300px;"
									  data-testid="query-name-input" />
						<MudIconButton Icon="@Icons.Material.Filled.Check"
									   Color="Color.Success"
									   Size="Size.Small"
									   OnClick="SaveRename"
									   Disabled="@(ValidateQueryName(_editedQueryName) != null)"
									   data-testid="query-rename-save-btn" />
						<MudIconButton Icon="@Icons.Material.Filled.Close"
									   Color="Color.Default"
									   Size="Size.Small"
									   OnClick="CancelRename"
									   data-testid="query-rename-cancel-btn" />
					}
					else
					{
						<MudText Typo="Typo.body1" data-testid="query-name-display">
							<strong>@(Workspace.Queries.GetCurrentQuery(Workspace.CurrentProject)?.Name ?? "New Query")</strong>
						</MudText>
						<MudTooltip Text="Rename query">
							<MudIconButton Icon="@Icons.Material.Filled.Edit" 
										   Size="Size.Small"
										   OnClick="StartRename"
										   data-testid="query-rename-btn" />
						</MudTooltip>
					}
					
					@if (Workspace.Queries.CurrentQueryIndex >= 0 && 
						 Workspace.Queries.OpenQueries.ContainsKey(Workspace.Queries.CurrentQueryIndex) &&
						 Workspace.Queries.OpenQueries[Workspace.Queries.CurrentQueryIndex].HasUnsavedChanges)
					{
						<MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Edit" data-testid="query-unsaved-indicator">Unsaved</MudChip>
					}
				</MudStack>
			</MudStack>
		</MudPaper>

		<!-- Monaco Editor -->
		<div class="editor-top" style="flex:1" data-testid="monaco-editor-container">
			@if (!Delay)
			{
				<StandaloneCodeEditor @ref="_editor" 
									  Id="editor-top" 
									  CssClass="editor" 
									  ConstructionOptions="EditorConstructionOptions" 
									  OnDidInit="OnEditorInitialized"
									  OnDidChangeModelContent="OnEditorContentChanged" />
			}
		</div>

		<!-- Editor Actions -->
		<MudPaper Class="pa-2" Elevation="1" data-testid="editor-info-bar">
			<MudText Typo="Typo.body2" Color="Color.Secondary">
				Editor provides IntelliSense using Roslyn compiler with EF Core support
			</MudText>
		</MudPaper>
	}
	else
	{
		<MudAlert Severity="Severity.Info" data-testid="no-project-alert">
			No project is open. Please create or open a project to start editing queries.
		</MudAlert>
	}
</div>
