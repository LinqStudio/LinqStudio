@using BlazorMonaco
@using BlazorMonaco.Editor
@using BlazorMonaco.Languages
@using LinqStudio.Abstractions.Models
@using LinqStudio.Blazor.Components

<!-- Query Info Bar -->
<MudPaper Class="pa-2 mb-1" Elevation="1" data-testid="query-info-bar">
	<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
		<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
			<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
			<MudText Typo="Typo.body1" data-testid="query-name-display">
				<strong>@(_currentQuery?.Name ?? "New Query")</strong>
			</MudText>

			@if (Workspace.Queries.OpenQueries.TryGetValue(QueryId, out var queryOpenState) && queryOpenState?.HasUnsavedChanges == true)
			{
				<MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Edit" data-testid="query-unsaved-indicator">Unsaved</MudChip>
			}
		</MudStack>

		<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
			<MudTooltip Text="Save query">
				<MudIconButton Icon="@Icons.Material.Filled.Save"
							   Color="Color.Primary"
							   Size="Size.Small"
							   OnClick="SaveCurrentQuery"
							   data-testid="query-save-btn" />
			</MudTooltip>

			<MudTooltip Text="Close query">
				<MudIconButton Icon="@Icons.Material.Filled.Close"
							   Color="Color.Primary"
							   Size="Size.Small"
							   OnClick="CloseCurrentQuery"
							   data-testid="query-close-btn" />
			</MudTooltip>
		</MudStack>
	</MudStack>
</MudPaper>

<!-- Editor and Results Container with Splitter -->
<div class="editor-results-container" style="flex:1">
	<!-- Monaco Editor -->
	<div class="editor-top" id="@EditorPanelId" style="height:40%" data-testid="monaco-editor-container">
		@if (!_delay)
		{
			<StandaloneCodeEditor @ref="_editor"
								  Id="@EditorId"
								  CssClass="editor"
								  ConstructionOptions="EditorConstructionOptions"
								  OnDidInit="OnEditorInitialized"
								  OnDidChangeModelContent="OnEditorContentChanged" />
		}
	</div>

	<!-- Draggable Splitter -->
	<div class="resize-splitter" id="@SplitterId" data-testid="editor-results-splitter"></div>

	<!-- Query Result Grid -->
	<div class="results-bottom" id="@ResultsPanelId" style="height:calc(60% - 5px); overflow:auto" data-testid="query-result-container">
		<!-- Query Execution Actions -->
		<MudPaper Class="pa-2" Elevation="1" data-testid="query-execution-bar">
			<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
					@if (_isExecuting)
					{
						<MudButton StartIcon="@Icons.Material.Filled.Stop"
								   Color="Color.Error"
								   Size="Size.Small"
								   Variant="Variant.Filled"
								   OnClick="StopQuery"
								   data-testid="stop-query-btn">
							Stop
						</MudButton>
					}
					else
					{
						<MudButton StartIcon="@Icons.Material.Filled.PlayArrow"
								   Color="Color.Primary"
								   Size="Size.Small"
								   Variant="Variant.Filled"
								   OnClick="ExecuteQueryAsync"
								   data-testid="execute-query-btn">
							Execute
						</MudButton>
					}

					<div data-testid="timeout-select">
						<MudSelect T="int"
								@bind-Value="_selectedTimeout"
								Variant="Variant.Outlined"
								Dense="true"
								Disabled="@_isExecuting">
							<MudSelectItem T="int" Value="10">10s</MudSelectItem>
							<MudSelectItem T="int" Value="30">30s</MudSelectItem>
							<MudSelectItem T="int" Value="60">1 min</MudSelectItem>
							<MudSelectItem T="int" Value="120">2 min</MudSelectItem>
							<MudSelectItem T="int" Value="300">5 min</MudSelectItem>
							<MudSelectItem T="int" Value="0">No timeout</MudSelectItem>
						</MudSelect>
					</div>
				</MudStack>

				<MudTooltip Text="Refresh IntelliSense schema from database">
					<MudButton StartIcon="@Icons.Material.Filled.Refresh"
							   Color="Color.Primary"
							   Size="Size.Small"
							   Variant="Variant.Text"
							   OnClick="@(() => OnRefreshSchemaRequested.InvokeAsync())"
							   Disabled="@(IsRefreshingSchema || !(Workspace.CurrentProject?.Connections.Any(c => c.QueryGenerator != null) ?? false))"
							   data-testid="refresh-schema-btn">
						@if (IsRefreshingSchema)
						{
							<MudProgressCircular Size="Size.Small" Indeterminate="true" />
							<span style="margin-left:4px">Refreshing...</span>
						}
						else
						{
							<span>Refresh Schema</span>
						}
					</MudButton>
				</MudTooltip>
			</MudStack>
		</MudPaper>

		<QueryResultGrid Result="@_result"
						 IsExecuting="@_isExecuting" />
	</div>
</div>
